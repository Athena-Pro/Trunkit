        "domain": "exact_int",
        "method": "comp_sql",
        "probe_sql": "WITH tri AS (SELECT x*(x+1)/2 AS v FROM generate_series(0,200) x WHERE x*(x+1)/2 <= 20000),\n      pent AS (SELECT y*(3*y+1)/2 AS v FROM generate_series(0,120) y WHERE y*(3*y+1)/2 <= 20000),\n      hept AS (SELECT z*(5*z+1)/2 AS v FROM generate_series(0,95) z WHERE z*(5*z+1)/2 <= 20000),\n      sums AS (SELECT DISTINCT t.v + p.v + h.v AS n FROM tri t, pent p, hept h WHERE t.v + p.v + h.v <= 20000),\n      missing AS (SELECT g.n FROM generate_series(0,20000) g(n) LEFT JOIN sums s ON s.n = g.n WHERE s.n IS NULL)\n SELECT (SELECT count(*) FROM missing) = 0,\n        jsonb_build_object('n_max', 20000, 'missing_count', (SELECT count(*) FROM missing), 'first_missing', (SELECT min(n) FROM missing))",
        "statement": "OEIS A287616 finite check: every integer 0 <= n <= 20000 is x(x+1)/2 + y(3y+1)/2 + z(5z+1)/2 with x,y,z natural",
